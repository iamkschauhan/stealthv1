rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Locked down until Auth + data model are wired.
    // Authenticated users can read/write only their own user doc.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
